//Create booking table
create table bookings (
booking_id int primary key auto_increment,
booking_employee int not null,
booking_customer int not null,
booking_haircut int not null,
booking_duration int not null DEFAULT 0,
booking_price double not NULL default 0,
booking_paid int not null,
booking_status ENUM('awiting', 'completed', 'cancelled') not null,
booking_date date,
booking_time time,
booking_creation_date datetime,
foreign key (booking_employee) references employee_info(employee_id),
foreign key (booking_customer) references customer_info(customer_id),
foreign key (booking_haircut) references haircut (haircut_id)
);

//Creating combined-key booking-treatment table
CREATE TABLE booking_treatment (
 booking_id INT NOT NULL,
 treatment_id INT NOT NULL,
 PRIMARY KEY (booking_id, treatment_id),
 CONSTRAINT fk_bt_booking FOREIGN KEY (booking_id) REFERENCES bookings(booking_id),
 CONSTRAINT fk_bt_treatment FOREIGN KEY (treatment_id) REFERENCES treatment(treatment_id)
 );